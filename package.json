{
  "name": "smart-file-logger",
  "version": "1.0.0",
  "description": "A production-ready, zero-dependency Node.js file logger with weekly log rotation, retention policy, Express middleware, and full TypeScript support.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build && npm run type-check && npm run lint",
    "clean": "rimraf dist coverage"
  },
  "keywords": [
    "logger",
    "file-logger",
    "log-rotation",
    "typescript",
    "nodejs",
    "express-middleware",
    "weekly-logs",
    "zero-dependency"
  ],
  "author": {
    "name": "smart-file-logger contributors"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RDarshankumar/Smart_File_Logger.git"
  },
  "bugs": {
    "url": "https://github.com/RDarshankumar/Smart_File_Logger/issues"
  },
  "homepage": "https://github.com/RDarshankumar/Smart_File_Logger#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.2.2",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "@types/express": ">=4.17.0"
  },
  "peerDependenciesMeta": {
    "@types/express": {
      "optional": true
    }
  }
}
